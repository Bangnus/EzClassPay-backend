generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  lineUid      String   @unique @map("line_uid")
  displayName  String   @map("display_name")
  pictureUrl   String?  @map("picture_url")
  role         String   @default("MEMBER")
  activeRoomId String?  @map("active_room_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  ownedRooms     Room[]        @relation("ManagerRooms")
  joinedRooms    RoomMember[]
  payments       Payment[]
  bills          Bill[]

  @@map("users")
}

model Room {
  id               String   @id @default(uuid())
  managerId        String   @map("manager_id")
  name             String
  collectionType   String   @default("TARGET") @map("collection_type")
  totalTargetAmount Float?  @map("total_target_amount")
  periodicAmount   Float?   @map("periodic_amount")
  promptpayNo      String   @map("promptpay_no")
  isPremium        Boolean  @default(false) @map("is_premium")
  lineGroupId      String?  @unique @map("line_group_id")
  createdAt        DateTime @default(now()) @map("created_at")

  manager      User          @relation("ManagerRooms", fields: [managerId], references: [id], onDelete: Restrict)
  members      RoomMember[]
  periods      Period[]
  expenses     Expense[]
  bills        Bill[]
  payments     Payment[]

  @@map("rooms")
}

model RoomMember {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_members")
}

model Period {
  id          String    @id @default(uuid())
  roomId      String    @map("room_id")
  name        String
  amount      Float
  createdAt   DateTime  @default(now()) @map("created_at")

  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@map("periods")
}

model Payment {
  id          String    @id @default(uuid())
  periodId    String?   @map("period_id")
  roomId      String?   @map("room_id")
  lineUid     String    @map("line_uid")
  slipUrl     String?   @map("slip_url")
  status      String    @default("PENDING") // "AWAITING_SLIP", "PENDING", "APPROVED", "REJECTED"
  createdAt   DateTime  @default(now()) @map("created_at")

  period      Period?   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  room        Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [lineUid], references: [lineUid], onDelete: Restrict)

  @@map("payments")
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float
  receiptUrl  String?  @map("receipt_url")
  createdAt   DateTime @default(now()) @map("created_at")
  roomId      String   @map("room_id")
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Bill {
  id        String   @id @default(uuid())
  month     Int
  year      Int
  dueDate   DateTime @map("due_date")
  amount    Float
  status    String   @default("UNPAID")
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, month, year])
  @@map("bills")
}
