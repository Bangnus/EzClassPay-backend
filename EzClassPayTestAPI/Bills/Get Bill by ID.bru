meta {
  name: Get Bill by ID
  type: http
  seq: 5
}

docs {
  ดึง bill ทีละรายการตาม id
}

get {
  url: {{base_url}}/bills/{{bill_id}}
  body: none
  auth: inherit
}

vars:pre-request {
  base_url: http://localhost:3000/api
  bill_id: 48d5dab3-242b-46e8-a7a2-f138f87bdc6d
}

settings {
  encodeUrl: true
  timeout: 0
}
