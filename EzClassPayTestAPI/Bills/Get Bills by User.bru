meta {
  name: Get Bills by User
  type: http
  seq: 2
}

docs {
  ดึง bill ของ user ที่指定 → ดูว่ามียอดค้างจ่ายอะไรบ้าง
}

get {
  url: {{base_url}}/bills/user/{{user_id}}?limit=5
  body: none
  auth: inherit
}

vars:post-response {
  user_id: res.body.data[0].userId
}

settings {
  encodeUrl: true
  timeout: 0
}

script:pre-request {
  const user_id = bru.getVar("user_id");
  if (!user_id) {
    bru.setVar("user_id", "314f47f3-b647-44ed-9026-4f76fbfe80b1");
  }
}
